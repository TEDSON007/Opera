<Window x:Class="Opera.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Opera"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800"
        DataContext="{Binding Source={RelativeSource Self}}"
        WindowState="Maximized">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Margin"
                    Value="5,0" />
        </Style>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="70" />
            <RowDefinition />
        </Grid.RowDefinitions>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition />
                <RowDefinition />
            </Grid.RowDefinitions>
            <StackPanel Orientation="Horizontal"
                        x:Name="NavPanel">
                <Button x:Name="btnNavBack"
                        Click="btnNavBack_Click"
                        Content="Back" />
                <Button x:Name="btnNavForward"
                        Click="btnNavForward_Click"
                        Content="Forward" />
                <Button x:Name="btnNavRefresh"
                        Click="btnNavRefresh_Click"
                        Content="Refresh" />
                <ComboBox x:Name="lbxAddress"
                          Margin="100, 0, 10, 0"
                          MinWidth="300"
                          ItemsSource="{Binding History}"
                          IsEditable="True" />
                <Button x:Name="btnSearch"
                        Click="btnSearch_Click"
                        Content="Search" />
                <Button x:Name="btnSettings"
                        Click="btnSettings_Click"
                        Content="Settings" />
            </StackPanel>
        </Grid>
        <local:NPTabControl x:Name="NPTabCon"
                            Grid.Row="1"
                            FlowDirection="LeftToRight"
                            Background="#222"
                            ItemsSource="{Binding TabItems}" />
    </Grid>
</Window>
