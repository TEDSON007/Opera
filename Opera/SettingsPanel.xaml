<UserControl x:Class="Opera.SettingsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Opera"
             xmlns:controls="clr-namespace:Opera.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40" />
            <RowDefinition Height="40" />
            <RowDefinition Height="40" />
            <RowDefinition Height="40" />
            <RowDefinition Height="40" />
            <RowDefinition Height="40" />
        </Grid.RowDefinitions>
        <Button x:Name="btnClose" 
                Width="80"
                HorizontalAlignment="Right"
                Content="Close"
                Click="btnClose_Click" />
        <controls:NPToggleButton x:Name="tbtnTheme"
                      Grid.Row="1"
                      Height="40"
                      Margin="10, 0"
                      Text="Test Property"
                      MouseLeftButtonUp="tbtnTheme_MouseLeftButtonUp">
        </controls:NPToggleButton>
        
    </Grid>
</UserControl>
