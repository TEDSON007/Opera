<UserControl x:Class="Opera.BrowserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Opera"
             xmlns:WebView2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
             mc:Ignorable="d" 
             Loaded="UserControl_Loaded"
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <Style TargetType="{x:Type Button}"
               >
            <Setter Property="Margin"
                    Value="5,0" />
        </Style>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="70" />
            <RowDefinition />
        </Grid.RowDefinitions>
        <WebView2:WebView2 Grid.Row="1"
                           x:Name="Browser"
                           ScrollViewer.VerticalScrollBarVisibility="Auto"
                           Margin="0"
                           HorizontalAlignment="Stretch"
                           VerticalAlignment="Stretch" />
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition />
                <RowDefinition />
            </Grid.RowDefinitions>
            <StackPanel Orientation="Horizontal"
                        x:Name="NavPanel">
                <Button x:Name="btnNavBack"
                        Click="btnNavBack_Click"
                        Content="Back" />
                <Button x:Name="btnNavForward"
                        Click="btnNavForward_Click"
                        Content="Forward" />
                <Button x:Name="btnNavRefresh"
                        Click="btnNavRefresh_Click"
                        Content="Refresh" />
                <ComboBox x:Name="lbxAddress"
                          Margin="100, 0, 10, 0"
                          MinWidth="300"
                          ItemsSource="{Binding History}"
                          IsEditable="True" />
                <Button x:Name="btnSearch"
                        Click="btnSearch_Click"
                        Content="Search" />
                <Button x:Name="btnSettings"
                        Click="btnSettings_Click"
                        Content="Settings" />
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
